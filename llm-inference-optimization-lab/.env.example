# LLM Inference Optimization Lab - Environment Configuration

# Model settings
DEFAULT_MODEL=gpt2
DRAFT_MODEL=distilgpt2
TARGET_MODEL=gpt2
DEVICE=cpu

# Service ports
ROUTER_PORT=8000
BASELINE_PORT=8001
QUANTIZED_PORT=8002
SPECULATIVE_PORT=8003
PREFILL_PORT=8004
DECODE_PORT=8005

# Service URLs (for inter-service communication)
BASELINE_URL=http://localhost:8001
QUANTIZED_URL=http://localhost:8002
SPECULATIVE_URL=http://localhost:8003
PREFILL_URL=http://localhost:8004
DECODE_URL=http://localhost:8005

# Logging
LOG_LEVEL=INFO
EVENT_LOG_DIR=./logs

# Benchmark
RESULTS_DIR=./results
